<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary_dark"
        android:paddingHorizontal="@dimen/padding_small">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="@dimen/text_size_title"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:gravity="center"
            tools:text="官子谱" />

        <!-- 改进的设置按钮 -->
        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_settings_button"
            android:paddingHorizontal="12dp"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnReset"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/reset"
            app:tint="@color/accent" />

    </LinearLayout>

    <!-- 试下模式指示器 - 加大样式，更醒目 -->
    <LinearLayout
        android:id="@+id/tvTrialMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FF8C00"
        android:gravity="center"
        android:paddingVertical="10dp"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="试下中 - 自由落子模式"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- 题目信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_large"
        android:paddingVertical="@dimen/padding_medium"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvProblemNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            tools:text="第 1/1708 题" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvToPlay"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_to_play_badge_dark"
            tools:text="黑先" />

    </LinearLayout>

    <!-- 棋盘区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/board_margin">

        <com.wangyu.gotsumego.ui.BoardView
            android:id="@+id/boardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <!-- 退出试下按钮 -->
        <Button
            android:id="@+id/btnExitTrial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:text="退出试下"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:background="@drawable/button_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone"
            tools:visibility="visible" />

    </FrameLayout>

    <!-- 反馈区域 -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_medium"
        android:textSize="@dimen/text_size_large"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        tools:text="完成!"
        tools:visibility="visible" />

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_small"
        android:textSize="@dimen/text_size_medium"
        android:textColor="@color/accent"
        android:gravity="center"
        android:visibility="gone"
        tools:text="解答说明"
        tools:visibility="visible" />

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/padding_medium"
        android:background="@color/card_background"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/prev_problem"
            android:background="@drawable/button_outline_background"
            android:textColor="@color/primary"
            android:layout_marginEnd="6dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnHint"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/show_hint"
            android:background="@drawable/bg_to_play_badge"
            android:textColor="@color/white"
            android:layout_marginHorizontal="6dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/next_problem"
            android:background="@drawable/button_background"
            android:textColor="@color/white"
            android:layout_marginStart="6dp"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
