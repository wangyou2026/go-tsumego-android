<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部标题区域 - 渐变背景 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_top"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            android:paddingHorizontal="@dimen/padding_large">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_title"
                android:textSize="56sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:shadowColor="#40000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="18sp"
                android:textColor="@color/text_on_primary"
                android:alpha="0.9"
                android:layout_marginTop="-8dp"
                android:letterSpacing="0.15" />

        </LinearLayout>

        <!-- 全部题目卡片 - 更醒目 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAllProblems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_large"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/accent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/all_problems"
                        android:textSize="20sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAllCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:alpha="0.8"
                        tools:text="共 1708 题" />

                </LinearLayout>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/primary"
                    android:contentDescription="@string/all_problems" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 书籍分类标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/all_books"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/padding_xlarge"
            android:layout_marginBottom="@dimen/padding_medium"
            android:layout_marginHorizontal="@dimen/card_margin_large" />

        <!-- 书籍分类 RecyclerView - 2列网格 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDifficulties"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/card_margin_large"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false" />

        <!-- 底部安全区 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>
