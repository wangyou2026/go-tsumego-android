<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部标题区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary_dark"
            android:paddingHorizontal="@dimen/padding_large"
            android:paddingTop="@dimen/padding_large"
            android:paddingBottom="@dimen/padding_medium">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="棋"
                android:textSize="40sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="围棋死活题"
                android:textSize="14sp"
                android:textColor="#8E8E93"
                android:letterSpacing="0.3"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/padding_medium"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAllCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#8E8E93"
                    tools:text="17,618 道题目" />

                <!-- 改进的设置按钮：更大的尺寸 + 圆形背景 + 图标 + 文字 -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_settings_button"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设置"
                        android:textSize="14sp"
                        android:textColor="@color/accent"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/cardAllProblems"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="全部题目 →"
                    android:textSize="13sp"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:background="@drawable/bg_to_play_badge"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- 书籍分类标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/book_section"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:paddingHorizontal="@dimen/padding_large"
            android:paddingTop="@dimen/padding_large"
            android:paddingBottom="@dimen/padding_small" />

        <!-- 书籍分类网格 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDifficulties"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/padding_medium"
            android:paddingBottom="@dimen/padding_large"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

    </LinearLayout>

</ScrollView>
